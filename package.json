{
  "name": "vaultchat",
  "version": "0.3.4",
  "description": "TUI AI chat client that stores conversations as markdown files",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "vaultchat": "src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "test": "bun test",
    "build": "bun build --compile src/index.tsx --outfile dist/vaultchat",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.tsx --outfile dist/vaultchat-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.tsx --outfile dist/vaultchat-linux-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.tsx --outfile dist/vaultchat-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.tsx --outfile dist/vaultchat-darwin-arm64",
    "smoke": "bun run scripts/smoke.ts",
    "doctor": "bun run scripts/doctor.ts",
    "doctor:json": "bun run scripts/doctor.ts --json",
    "doctor:report": "bun run scripts/doctor.ts --out reports/doctor.json",
    "hardening": "bun run smoke && bun run doctor",
    "hardening:strict": "bunx tsc --noEmit && bun run hardening"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "cli-highlight": "^2.1.11",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "marked": "^18",
    "marked-terminal": "^7",
    "react": "^19.2.5"
  }
}
